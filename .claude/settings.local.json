{
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:8787"
  },
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(npx tsc *)",
      "Bash(npm run *)",
      "Bash(.venv/bin/python3 -m py_compile src/app/caldav/write.py)",
      "Bash(.venv/bin/python3 -m py_compile src/app/main.py)",
      "Bash(.venv/bin/python3 -m py_compile src/app/caldav/sync.py)",
      "Bash(grep -E '\\\\.\\(ts|tsx|py|js\\)$')",
      "Bash(git *)",
      "Bash(python3 *)"
    ]
  }
}
