# Termina – Konfiguration
# Kopieren nach .env und ausfuellen (niemals .env in Git einchecken!)

# CalDAV-Verbindung
CALDAV_URL=https://oxicloud.skords.de/caldav
CALDAV_USERNAME=deinuser
CALDAV_PASSWORD=deinpasswort

# Sync-Intervall in Sekunden (Default: 300 = 5 Minuten)
SYNC_INTERVAL_SECONDS=300

# Datenbank (SQLite-Pfad relativ zum Arbeitsverzeichnis)
DATABASE_URL=sqlite:///./termina.db

# Initialer Admin-Account, wird nur beim allerersten Start angelegt
# (solange noch keine User in der DB existieren)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=aendere-mich-in-einen-sicheren-zufallswert

# Session-Cookie nur ueber HTTPS senden (true in Prod, false fuer lokales HTTP-Dev)
COOKIE_SECURE=false

# CORS (kommasepariert; fuer Prod auf die echte Frontend-Domain setzen)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Externe ICS-Feeds (read-only, JSON-Array)
# webcal:// wird automatisch zu https:// umgeschrieben
ICS_FEEDS=[{"url":"webcal://backend.stadtreinigung.hamburg/kalender/abholtermine.ics?hnIds=170992","name":"Stadtreinigung","color":"#FF6600"},{"url":"https://ics.tools/Ferien/hamburg.ics","name":"Ferien Hamburg","color":"#4CAF50"}]

# Kalenderfarben (JSON-Objekt: Kalender-Name → Hex-Farbe, Substring-Match, case-insensitiv)
CALENDAR_COLORS={"Samu":"#D63031","Sanna":"#FFC300","Silja":"#967BB6","Smilla":"#3A7BD5","Sophine":"#E84393","Sven":"#8B2500","Familie":"#27AE60"}
