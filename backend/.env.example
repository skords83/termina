# Termina – Konfiguration
# Kopieren nach .env und ausfuellen (niemals .env in Git einchecken!)

# CalDAV-Verbindung
CALDAV_URL=https://nextcloud.example.com/remote.php/dav
CALDAV_USERNAME=deinuser
CALDAV_PASSWORD=deinpasswort

# Sync-Intervall in Sekunden (Default: 300 = 5 Minuten)
SYNC_INTERVAL_SECONDS=300

# Datenbank (SQLite-Pfad relativ zum Arbeitsverzeichnis)
DATABASE_URL=sqlite:///./termina.db

# Statisches API-Token fuer Phase 2 (beliebiger langer zufaelliger String)
API_TOKEN=aendere-mich-in-einen-sicheren-zufallswert

# CORS (kommasepariert; fuer Prod auf die echte Frontend-Domain setzen)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
