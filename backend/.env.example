# Termina – Konfiguration
# Kopieren nach .env und ausfuellen (niemals .env in Git einchecken!)

# CalDAV-Verbindung
CALDAV_URL=https://oxicloud.skords.de/caldav
CALDAV_USERNAME=deinuser
CALDAV_PASSWORD=deinpasswort

# Sync-Intervall in Sekunden (Default: 300 = 5 Minuten)
SYNC_INTERVAL_SECONDS=300

# Datenbank (SQLite-Pfad relativ zum Arbeitsverzeichnis)
DATABASE_URL=sqlite:///./termina.db

# Statisches API-Token fuer Phase 2 (beliebiger langer zufaelliger String)
API_TOKEN=aendere-mich-in-einen-sicheren-zufallswert

# CORS (kommasepariert; fuer Prod auf die echte Frontend-Domain setzen)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Externe ICS-Feeds (read-only, JSON-Array)
# webcal:// wird automatisch zu https:// umgeschrieben
ICS_FEEDS=[{"url":"webcal://backend.stadtreinigung.hamburg/kalender/abholtermine.ics?hnIds=170992","name":"Stadtreinigung","color":"#f59e0b"},{"url":"https://ics.tools/Ferien/hamburg.ics","name":"Ferien Hamburg","color":"#10b981"}]

# Kalenderfarben (JSON-Objekt: Kalender-Name → Hex-Farbe, Substring-Match, case-insensitiv)
CALENDAR_COLORS={"Samu":"#f0a500","Sanna":"#e85d3a","Silja":"#ec4899","Smilla":"#1565c0","Sophine":"#9b59b6","Sven":"#4a9eed","Familie":"#5cb85c"}
