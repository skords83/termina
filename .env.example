# --- Nextcloud CalDAV ---
# Voller URL des CalDAV-Endpoints, typisch:
#   https://cloud.example.com/remote.php/dav
NEXTCLOUD_URL=https://cloud.example.com/remote.php/dav
NEXTCLOUD_USERNAME=your-username
# In Nextcloud unter "Sicherheit -> Geräte & Sitzungen -> Neues App-Passwort"
NEXTCLOUD_APP_PASSWORD=

# --- Backend ---
SYNC_INTERVAL_SECONDS=300
# SQLite-Datei landet im Container unter /data (durch Compose auf ./data gemountet)
DATABASE_URL=sqlite:////data/termina.db
# Erlaubte CORS-Origins (kommagetrennt). Im Prod-Setup mit nginx-Proxy kann dies leer bleiben.
CORS_ORIGINS=["http://localhost:5173"]

# --- Auth ---
# Wird nur beim allerersten Start verwendet, um den initialen Admin-Account
# anzulegen (nur solange noch keine User in der DB existieren).
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-to-a-random-string
# Session-Cookie nur ueber HTTPS senden. In Prod (hinter Traefik/HTTPS) true,
# fuer lokales HTTP-Dev false.
COOKIE_SECURE=true

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
